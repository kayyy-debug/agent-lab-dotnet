<div class="start-screen">
    <div class="start-inner">

        <div class="brand-mark">🎲</div>
        <h1 class="brand-name">Soc Ops</h1>
        <p class="brand-tagline">Social Bingo</p>

        <div class="how-to-card">
            <p class="how-to-label">How to play</p>
            <ul class="rules-list">
                <li>
                    <span class="rule-badge">1</span>
                    Find people around you who match each square
                </li>
                <li>
                    <span class="rule-badge">2</span>
                    Tap a square when you find a match
                </li>
                <li>
                    <span class="rule-badge">🏆</span>
                    Get 5 in a row to win!
                </li>
            </ul>
        </div>

        <button @onclick="OnStart" class="btn-start">
            Start Game
        </button>

    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
